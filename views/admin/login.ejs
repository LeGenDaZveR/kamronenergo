<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <title>Admin Login</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<section class="news-section">
  <h2>Admin Login</h2>

  <div style="max-width:420px;margin:0 auto;background:#fff;padding:20px;border-radius:10px;">
    <% if(error){ %>
      <p style="color:red;font-weight:bold;"><%= error %></p>
    <% } %>

    <form method="POST" action="/admin/login">
      <input style="width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;margin-bottom:10px;"
             name="username" placeholder="Username" required>

      <input style="width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;margin-bottom:10px;"
             type="password" name="password" placeholder="Password" required>

      <button style="padding:10px 16px;border:none;border-radius:8px;font-weight:bold;cursor:pointer;background:#118af5;color:#fff;width:100%;"
              type="submit">
        Kirish
      </button>
    </form>
  </div>
</section>

</body>
</html>
